{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "checkJs": false,
    "baseUrl": "../../",
    "paths": {
      "@/*": ["src/*"],
      "@ai/*": ["src/ai/*"],
      "@memory/*": ["src/memory/*"],
      "@handlers/*": ["src/handlers/*"],
      "@models/*": ["src/models/*"],
      "@pages/*": ["src/pages/*"],
      "@messenger/*": ["src/messenger/*"]
    }
  },
  "exclude": ["node_modules"]
}
