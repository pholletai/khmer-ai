{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "checkJs": false,
    "baseUrl": "./",          // ✅ root of project
    "paths": {
      "@/*":          ["src/*"],
      "@ai/*":        ["src/ai/*"],
      "@memory/*":    ["src/memory/*"],
      "@handlers/*":  ["src/handlers/*"],
      "@models/*":    ["src/models/*"],
      "@pages/*":     ["src/pages/*"],
      "@messenger/*": ["src/messenger/*"]
    }
  },
  "include": ["src/**/*"],   // ✅ បន្ថែម include
  "exclude": ["node_modules"]
}